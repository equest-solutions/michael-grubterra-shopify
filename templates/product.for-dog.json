    "custom_grub_terra_features_WJqKT3": {
      "type": "custom-grub-terra-features",
      "blocks": {
        "text_V44abN": {
          "type": "text",
          "settings": {
            "text": "<h3><strong>All Ingredients sourced in the USA</strong></h3><p>All our salmon and beef used in our Moo Munches, Bully Bites, and Salmon Snacks are sourced from the USA. </p><h3><strong>Nutritious Treat</strong></h3><p>High in protein, Healthy fats and a single ingredient treat! Made to have your dog licking there lips every time you pull the bag out. </p><h3><strong>Freeze Dried for freshness!</strong></h3><p>These three treats are all freeze dried to save the freshness. This gives your dog a great chewing experience when they take there first bite into this fresh single ingredient treat. </p>"
          }
        }
      },
      "block_order": [
        "text_V44abN"
      ],
      "settings": {
        "title": "Sustainably manufactured and sourced in the USA",
        "image": "shopify://shop_images/POSTED_2.15.2023.jpg",
        "image_position": "left",
        "padding_top": 40,
        "padding_bottom": 20
      }
    },
    "custom_grub_terra_features_Gd8Wnq": {
      "type": "custom-grub-terra-features",
      "blocks": {
        "text_zUxAJX": {
          "type": "text",
          "settings": {
            "text": "<h3><strong>NO PRESERVATIVES</strong></h3><p>No additives. No preservatives. Great for large and medium sized dogs. Also good for small dogs but please monitor your dogs when chewing.</p><h3><strong>STRONGER EGGSHELLS</strong></h3><p>With 75x more calcium than mealworms, GrubTerra grubs will help your flock lay strong and consistent eggs.</p><h3><strong>HEALTHIER FEATHER PRODUCTION</strong></h3><p>GrubTerras Grubs promote stronger eggshells and help hens increase their energy levels and egg production. Grubterra Grubs are also a great supplement during molting season and in the cold winter months!</p>"
          }
        }
      },
      "block_order": [
        "text_zUxAJX"
      ],
      "settings": {
        "title": "",
        "image": "shopify://shop_images/Rectangle_16.png",
        "image_position": "right",
        "padding_top": 0,
        "padding_bottom": 20
      }
