<link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.css">
<link
  rel="stylesheet"
  type="text/css"
  href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick-theme.css"
>
<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script
  type="text/javascript"
  src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.min.js"
></script>
{% schema %}
{
  "name": "Icon Grid Marquee",
  "settings": [
  ],
  "blocks": [
    {
      "type": "icon_text_block",
      "name": "Icon with Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "icon_title",
          "label": "Icon Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Grid Marquee",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<div class="icon-grid-marquee">
  <div class="page-width">
    <div class="icon-grid hide_in_mobile">
      {% for block in section.blocks %}
        <div class="icon-text-item">
          {% if block.settings.icon_image != blank %}
            <img src="{{ block.settings.icon_image | img_url: '200x' }}" alt="{{ block.settings.icon_title }}">
          {% endif %}
          <h3>{{ block.settings.icon_title }}</h3>
        </div>
      {% endfor %}
    </div>
    <div class="show_in_mobile">
      <div class="responsive_slick_slider">
        {% for block in section.blocks %}
          <div>
            <div class="icon-text-item">
              {% if block.settings.icon_image != blank %}
                <img src="{{ block.settings.icon_image | img_url: '200x' }}" alt="{{ block.settings.icon_title }}">
              {% endif %}
              <h3>{{ block.settings.icon_title }}</h3>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>


 

{% style %}




        .icon-grid-marquee {
          text-align: center;
          padding:5px 0;
              background: #1F6223;
        }

        .icon-grid {
          display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        }

        .icon-text-item {
          text-align: center;
        display: flex;
        align-items: center;
        gap: 10px;
        /* width: 100%; */
        justify-content: center;
        }

        .icon-text-item img {
          max-width: 100%;
        }
      .icon-text-item h3{
      font-family: 'Brother1816 Printed';
      font-size: 14px;
      font-weight: 350;
      line-height: 21.6px;
      text-align: left;
        margin:0 !important;
      color:#fff;
      }

  .show_in_mobile{
    display:none;
  }
      @media(max-width: 600px){
        .chicken-landing-page  .icon-grid-marquee{
          padding:4px !important;
        }
        .slick-slide div:nth-child(1){
          display:flex;
        }
.icon-grid {display:none;}

.icon-text-item img {width:25px !important; margin:0 !important;}

    .responsive_slick_slider .icon-text-item{
      display:flex !important;
    }
         .show_in_mobile{
    display:block;
  }
      }
{% endstyle %}

