<script>
document.addEventListener('DOMContentLoaded', function() {
  setTimeout(function() {
    console.log('Status: loaded'); // Log when the script loads after 6 seconds

    const selectElement = document.getElementById('appstle_selling_plan0');
    const radioButton = document.querySelector('input[name="selling_plan"][type="radio"]');
    const formIds = [
      '#product-form-template--16016691462257__custom_featured_product_WR3Upi',
      '#product-form-template--16016691495025__custom_featured_product_WR3Upi',
      '#product-form-template--16016691527793__custom_featured_product_WR3Upi',
      '#product-form-template--16016691560561__custom_featured_product_WR3Upi',
      '#product-form-template--16016691593329__custom_featured_product_WR3Upi',
      '#product-form-template--15780452728945__custom_featured_product_WR3Upi',
      '#product-form-template--15776977125489__custom_featured_product_RMDhWn'
    ];

    formIds.forEach(formId => {
      let form = document.querySelector(formId);

      if (form) {
        console.log('Form found:', form);

        // Create the hidden input for the selling plan if it doesn't exist
        let sellingPlanInput = form.querySelector('input[name="selling_plan"][type="hidden"]');
        if (!sellingPlanInput) {
          sellingPlanInput = document.createElement('input');
          sellingPlanInput.type = 'hidden';
          sellingPlanInput.name = 'selling_plan';
          form.appendChild(sellingPlanInput);
          console.log('Hidden selling plan input added to form:', sellingPlanInput);
        } else {
          console.log('Selling plan input already exists:', sellingPlanInput);
        }

        if (selectElement) {
          console.log('Select element found:', selectElement);
          selectElement.addEventListener('change', function() {
            const selectedOption = selectElement.options[selectElement.selectedIndex];
            console.log(`Selected option: ${selectedOption.text} (Value: ${selectedOption.value})`);

            sellingPlanInput.value = selectedOption.value;
            console.log('Selling plan input value set to:', sellingPlanInput.value);
          });
        } else {
          console.error('Select element not found');
        }

        if (radioButton) {
          radioButton.addEventListener('change', function() {
            if (this.value === "") {
              sellingPlanInput.value = "";
              console.log('Selling plan input value removed');
            }
          });
        }
      } else {
        console.error('Form not found with ID:', formId);
      }
    });
  }, 6000); // 6-second delay for DOMContentLoaded
});
</script>