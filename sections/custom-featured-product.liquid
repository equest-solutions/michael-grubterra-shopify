<script>
  document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM fully loaded and parsed');

    const radioButtons = document.querySelectorAll('.js-variant-quantity');
    console.log('Radio buttons found:', radioButtons);

    const formIds = [
      '#product-form-template--16016691462257__custom_featured_product_WR3Upi',
      '#product-form-template--16016691495025__custom_featured_product_WR3Upi',
      '#product-form-template--16016691527793__custom_featured_product_WR3Upi',
      '#product-form-template--16016691560561__custom_featured_product_WR3Upi',
      '#product-form-template--16016691593329__custom_featured_product_WR3Upi',
      '#product-form-template--15780452728945__custom_featured_product_WR3Upi',
      '#product-form-template--15776977125489__custom_featured_product_RMDhWn'
    ];

    formIds.forEach(formId => {
      let form = document.querySelector(formId);
      console.log('Form found:', form);

      if (form) {
        const quantityInput = document.createElement('input');
        quantityInput.type = 'hidden';
        quantityInput.name = 'quantity';
        form.appendChild(quantityInput);
        console.log('Hidden quantity input added to form:', quantityInput);

        radioButtons.forEach(radio => {
          radio.addEventListener('change', function() {
            quantityInput.value = this.dataset.quantity;
            console.log('Radio button changed:', this);
            console.log('Quantity input value set to:', quantityInput.value);
          });
        });

        // Set initial quantity if a radio button is already selected
        const selectedRadio = document.querySelector('.js-variant-quantity:checked');
        if (selectedRadio) {
          quantityInput.value = selectedRadio.dataset.quantity;
          console.log('Initial selected radio button:', selectedRadio);
          console.log('Initial quantity input value set to:', quantityInput.value);
        }
      } else {
        console.error('No form found with the specified ID:', formId);
      }
    });
  });
</script>
























