<script>
document.addEventListener('DOMContentLoaded', function() {
  setTimeout(function() {
    const radioButtons = document.querySelectorAll('input[name="selling_plan"]');

    radioButtons.forEach(radio => {
      radio.addEventListener('change', function() {
        // Remove the class from all options
        document.querySelectorAll('.appstle_subscription_wrapper_option').forEach(option => {
          option.classList.remove('selected-option');
        });

        // Add the class to the selected option
        if (radio.checked) {
          radio.closest('.appstle_subscription_wrapper_option').classList.add('selected-option');
          console.log(`Selected selling plan: ${radio.value}`);
        }
      });
    });
  }, 8000); // 5-second delay
});
</script>



