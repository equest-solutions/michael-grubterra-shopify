{%- style -%}
  #shopify-section-sections--15776971489393__newsletter_wiVQ6x {display:none;}

  .product--medium:not(.product--no-media) .product__media-wrapper {max-width:45%;}
  .product--medium:not(.product--no-media) .product__info-wrapper {max-width:min-content;}
  html {
      scroll-behavior: smooth;
  }


    .product__view-details {display:none;}
  .gurented-container {background-color:#F2F9F3;}


  .icon-with-text-custom.loop-7 .icon-with-text img {
    height: 80px;
    width: auto;
  }

   .featured_product_bg  {background-color:#F2F9F3;}
          .featured_product_bg .product__info-wrapper h2.product__title{
                  text-transform: uppercase;
                  font-family: "Brother1816 Printed Bold";
                  font-size: 40px;
                  font-weight: 700;
                  line-height: 48px;
                  letter-spacing: -0.02em;
                  text-align: left;
                  color:#1F6223;
            }

         .featured_product_bg  .product-form__submit:before,
         .featured_product_bg  .product-form__submit:after,
         .featured_product_bg  .product-form__input input[type=radio]:checked+label:before {
          box-shadow: none !important;
          }
         .featured_product_bg  .next-one-next.slick-arrow{
          position: absolute;
          top: 50%;
          left: 2%;
          z-index: 1;
          cursor:pointer;
        }
         .featured_product_bg  .next-one.slick-arrow{
          position: absolute;
          top: 50%;
          right: 2%;
          z-index: 1;
          cursor:pointer;
        }
        .featured_product_bg  .icon-with-text-custom.loop-8 span.h4.inline-richtext {
          font-size: 15px;
          line-height: 24px;
          font-weight: 700;
          font-family: 'Brother1816 Printed';
      }
        .featured_product_bg .shoppay svg{
           width:100%;
        }

         .featured_product_bg .icon-with-text-custom.loop-4 li{
           margin-bottom:0px;
         }
        .featured_product_bg .icon-with-text-custom.loop-4 span.h4.inline-richtext{
          font-size: 17px;
          line-height: 25px;
          font-family: 'Brother1816 Printed';
        }
        .featured_product_bg .product__title.h1{
          margin: 0;
        }
       .featured_product_bg p.product__text.inline-richtext.subtitle {
          font-size: 20px;
          line-height: 28px;
          color: black;
          font-family: 'Brother1816 Printed';
      }
        .featured_product_bg .review-stars svg{
            display: block;
            margin-bottom: 1.5%;
        }
        .featured_product_bg .review-content{
          text-align:left;
        }
        .featured_product_bg .review-main h6{
         margin: 0;
          font-size: 16px;
          line-height: 22.4px;
          display: flex;
          gap: 6px;
          font-family: 'Brother1816 Printed Bold';
          align-items: center;
        }
        .featured_product_bg .review-image img{
          display:block;
          width:90px;
        }
        .featured_product_bg .review-main .review-author{
              margin-top: 1%;
        }
        .featured_product_bg .review-text p{
          margin: 0;
          font-size: 16px;
          line-height: 22.4px;
          color: black;
          font-family: 'Brother1816 Printed';
          font-weight:350;
        }
        .featured_product_bg .review-main{
          display: flex;
          padding: 0%;
          width: 80%;
          margin-top: 5%;
          justify-content: center;
          margin: auto;
          margin-top: 5%;
          gap: 16px;
          align-items: center;
        }
        .featured_product_bg .product-form__buttons button span{
          font-size: 22px;
          color:white;
          font-weight:700;
          text-transform:uppercase;
          line-height:22px;
          font-family: 'Brother1816 Printed Bold';
        }
        .featured_product_bg .product-form__buttons button{
          background: #F87212;
          border-radius:100px;
        }
        .featured_product_bg .product-form__buttons {
          max-width: 100%;
        }
       .featured_product_bg ul.list.list-payment{
          list-style: none;
          display: flex;
          justify-content: space-between;
          padding: 0;
          width: 100% !important;
        }
        .featured_product_bg .featured-product.product{
          padding:0;
        }
        .icon-with-text-custom.loop-4 ul.icon-with-text{
          display: flex;
          gap: 18px;
          align-items: center;
        }
        .icon-with-text-custom.loop-8 .icon-with-text img{
          width:85px;
          height:85px;
        }
        .featured_product_bg .product__info-container{
          text-align:left;
        }
            .section-{{ section.id }}-padding {
              padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
              padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
            }
        .safe-secure{
          text-align:center;
        }
    .product-form__submit, .product-form__input input[type=radio]:checked+label {
        background-color: #1f6223;
        background: #1f6223;
        color: white;
        border: 1px solid white;
    }
    @media screen and (min-width: 990px){
         .featured_product_bg .product__info-wrapper{
       padding: 0px 0px 0px 5rem !important;
     }
      .featured_product_bg {
        padding:60px 0;
      }
    }
            @media screen and (min-width: 750px) {
              .desktop-hide{
                display:none !important;
              }
              .featured_product_bg .page-width{
                 margin:0 auto;
              }
              .section-{{ section.id }}-padding {
                padding-top: {{ section.settings.padding_top }}px;
                padding-bottom: {{ section.settings.padding_bottom }}px;
              }
            }





            @media screen and (max-width: 749px){


  .appstle_widget_title {font-size:14px;}


  .product--medium:not(.product--no-media) .product__media-wrapper {max-width:100%;}
  .product--medium:not(.product--no-media) .product__info-wrapper {max-width:100%;}


  .icon-with-text-custom.loop-7 .icon-with-text img {
    height: 40px;
    width: auto;
  }

    .icon-with-text-custom.loop-7 .icon-with-text__item:nth-child(1) {
      order: 3;
    }

    .icon-with-text-custom.loop-7 .icon-with-text__item:nth-child(2) {
      order: 4;
    }


  .icon-with-text-custom.loop-7 .icon-with-text--horizontal {
  flex-wrap:wrap;
      row-gap: 10px;

  }

              .featured_product_bg .review-main h6 svg,
              .review-stars svg {
                  width: auto !important;
              }
              .featured_product_bg .review-main h6 {
                   font-size: 14px;
                  line-height: 20px;
                  gap: 19px;
              }
              .featured_product_bg .review-text p {
                  margin: 0;
                  font-size: 14px;
                  line-height: 20px;
              }
              .featured_product_bg .review-main {
                   width: 100%;
              }
              .featured_product_bg .review-image img {
                  width: 56px;
              }
              .product__info-wrapper{
                margin-top: 10%;
              }
              .desktop-hide svg{
                width:100%;
              }
              .icon-with-text-custom.loop-8 ul.icon-with-text{
                flex-wrap:wrap;
              }
              .icon-with-text-custom.loop-8 .icon-with-text img {
                  width: 42px;
                  height: 42px;
              }
              .featured_product_bg .icon-with-text-custom.loop-8 span.h4.inline-richtext {
                  font-size: 16px;
                  line-height: 21px;
                  margin-bottom: 12%;
                }
              .featured_product_bg .product-form__buttons button span {
                font-size: 18px;
              }
              .mobile-hide{
                display:none !important;
              }
              .icon-with-text-custom.loop-4 ul.icon-with-text .icon-with-text__item{
                margin-bottom:3% !important;
              }
              .icon-with-text-custom.loop-4 ul.icon-with-text{
                display:block;
              }
              .featured_product_bg .icon-with-text-custom.loop-4 span.h4.inline-richtext {
                  font-size: 16px;
                  line-height: 22px;
                  font-family: 'Brother1816 Printed';
              }
             .featured_product_bg .custom_liquid svg{
                width:90%;
              }
              .featured_product_bg p.product__text.inline-richtext.subtitle {
                font-size: 16px;
                line-height: 22px;
                color: black;
                font-family: 'Brother1816 Printed';
            }
              .featured_product_bg .product__info-wrapper h2.product__title {
                    font-size: 26px;
                        text-transform: uppercase;
                    line-height: 29px;
                }
            }
