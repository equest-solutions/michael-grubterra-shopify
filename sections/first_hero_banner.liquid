{% schema %}
{
  "name": "Hero Banner Grid",
  "settings": [
            {
      "type": "image_picker",
      "id": "short_review_icon_two",
      "label": "Short Icon Image"
    },
    {
      "type": "inline_richtext",
      "id": "short_review_content_two",
      "label": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Shop"
    },
    {
      "type": "inline_richtext",
      "id": "content",
      "label": "Content"
    },

    {
      "type": "url",
      "id": "button2_url",
      "label": "Button 2 URL"
    },
    {
      "type": "text",
      "id": "button2_text",
      "label": "Button 2 Text",
      "default": "Learn More"
    },
    {
      "type": "inline_richtext",
      "id": "review_content",
      "label": "Review Content",
      "default": "This is the best product I have ever used!"
    },
    {
      "type": "text",
      "id": "review_author",
      "label": "Review Author",
      "default": "John Doe"
    },
    {
      "type": "text",
      "id": "verify_customer",
      "label": "Client Review",
      "default": "Verified Customers"
    },

    {
      "type": "image_picker",
      "id": "short_review_author_icon",
      "label": "Author Icon Image"
    },
 {
      "type": "image_picker",
      "id": "short_review_stars_icon",
      "label": "Stars Icon Image"
    },
    {
      "type": "image_picker",
      "id": "second_container_image",
      "label": "Second Container Image"
    },
{
      "type": "image_picker",
      "id": "hero_overlay_image",
      "label": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "hero_overlay_image_mobile",
      "label": "Hero image Mobile"
    }

  ],
  "blocks": [
    {
      "type": "List_Items",
      "name": "List",
      "settings": [
        {
          "type": "image_picker",
          "id": "list_image",
          "label": "List Image"
        },
        {
          "type": "inline_richtext",
          "id": "list_content",
          "label": "List content"
        }
      ]
    },
     {
      "type": "List_Items_one",
      "name": "List Two",
      "settings": [
        {
          "type": "text",
          "id": "list_content_heading",
          "label": "List Heading"
        },
        {
          "type": "inline_richtext",
          "id": "list_content_subheading",
          "label": "List content Two"
        }
      ]
    },
     {
      "type": "logo-slider",
      "name": "logo slider",
      "settings": [
       {
          "type": "text",
          "id": "text",
          "label": "Heading"
        },
        {
          "type": "image_picker",
          "id": "logo1",
          "label": "logo"
        },
        {
          "type": "image_picker",
          "id": "logo2",
          "label": "logo"
        },
        {
          "type": "image_picker",
          "id": "logo3",
          "label": "logo"
        },
        {
          "type": "image_picker",
          "id": "logo4",
          "label": "logo"
        },
        {
          "type": "image_picker",
          "id": "logo5",
          "label": "logo"
        }
      ]
    }
],
  "presets": [
    {
      "name": "Hero Banner Grid",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}

<section class="hero-banner-two">
  <div class="hero-flex-container">
    <div class="hero-flex-first">
      <div class="short_review_container">
        <img src="{{ section.settings.short_review_icon_two | img_url:'medium'}}" alt="">
        <p>{{ section.settings.short_review_content_two }}</p>
      </div>
      <h1>{{ section.settings.heading }}</h1>
      <p class="hero-para-one">{{ section.settings.content }}</p>
      <div class="hero-banner-second_image show_in_mobile">
        <img src="{{ section.settings.second_container_image | img_url:'master'}}" alt="">
      </div>
      <div class="hero_first_list">
        {% for block in section.blocks %}
          {% if block.type == 'List_Items' %}
            <div class="list_content_container">
              <img src="{{ block.settings.list_image | img_url:'medium'}}" alt="">
              <p>{{ block.settings.list_content }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="buttons_container">
        {% if section.settings.button2_text != blank %}
          <a href="{{ section.settings.button2_url }}" class="btn btn-secondary">
            {{- section.settings.button2_text }}
            {% render 'arrow_right_custom' %}
          </a>

  <div class="safe-secure">
          {% render 'safe-secure' %}
        </div>

        {% endif %}
      </div>

      {% if section.settings.review_content != blank %}
        <div class="review-container">
          <div class="author_icon_position">
            <img src="{{ section.settings.short_review_author_icon | img_url:'medium'}}" alt="">
          </div>
          <div>
            <img src="{{ section.settings.short_review_stars_icon | img_url:'medium'}}" alt="">
            <p class="author_reviews_custom">{{ section.settings.review_content }}</p>

            <div class="author_sub_content_two">
              <p class="author_name_content">
                <strong>{{ section.settings.review_author }}</strong>
              </p>
              <p class="client_icon_verify">
                {% render 'verify_customer' %}
                {{ section.settings.verify_customer }}
              </p>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
    <div class="hero-flex-second hide_in_mobile">
      <div class="hero-banner-second_image">
        <img src="{{ section.settings.second_container_image | img_url:'master'}}" alt="">
      </div>
    </div>
  </div>

  <section class="hero_overlay_section">
    <div class="page-width">
      <div class="hero_overlay_flex">
        {% for block in section.blocks %}
          {% if block.type == 'logo-slider' %}
            {% render 'logo-slider-banner', block: block %}
          {% endif %}
        {% endfor %}

        <!--
          {% for block in section.blocks %}
            {% if block.type == 'List_Items_one' %}
              <div class="hero_overlay_flex_container">
                <h2>{{ block.settings.list_content_heading }}</h2>
                <p>{{ block.settings.list_content_subheading }}</p>
              </div>
            {% endif %}
          {% endfor %}
        -->
      </div>
    </div>
  </section>
</section>

{% style %}
