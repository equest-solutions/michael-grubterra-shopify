          align-items: center;
          gap: 10px;
      }
      .review-container .author_name_content {
          font-family: "Brother1816 Printed Bold";
          font-size: 16px;
          font-weight: 500;
          line-height: 22.4px;
          text-align: left;
          margin: 0;
      }
      .review-container .client_icon_verify {
