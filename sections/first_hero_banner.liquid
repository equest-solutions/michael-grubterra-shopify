      }
      .hero-banner-second_image img {
          width: 100%;
      }

      .hero_overlay_section {
          background-size: cover;
          background-repeat: no-repeat;
          background-image: url("{{ section.settings.hero_overlay_image | img_url: 'master' }}");
          padding: 96px 0px 60px 0;
          background-position: center;
          position: relative;
  top: -175px;

      }
      .hero_overlay_flex {
          display: flex;
          align-items: center;
          justify-content: space-between;
      }
      .hero_overlay_flex_container {
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 10px;
      }
      .hero_overlay_flex_container h2 {
          font-family: "Brother1816 Printed Bold";
          font-size: 60px;
          font-weight: 700;
          line-height: 84px;
          text-align: left;
          color: #1f6223;
          margin: 0;
      }
      .hero_overlay_flex_container p {
          font-family: "Brother1816 Printed Bold";
