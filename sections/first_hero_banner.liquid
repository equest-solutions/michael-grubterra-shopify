      .review-container {
          display: flex;
          align-items: center;
          gap: 20px;
      }
    .review-container  .author_reviews_custom {
          font-family: "Brother1816 Printed";
          font-size: 16px;
          font-weight: 350;
          line-height: 22.4px;
          text-align: left;
          margin: 0;
          margin-bottom: 12px;
      font-weight:600;
      }
     .review-container .author_sub_content_two {
