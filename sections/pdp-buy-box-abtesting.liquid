                                                    Free Shipping
                                                </div>
                                            {% elsif forloop_index_count == 5  %}
                                                <div class="badge free-shipping">
                                                    Free Shipping
                                                </div>
                                            {% elsif forloop_index_count == 6  %}
                                                <div class="badge best-value">
                                                    Free Shipping + Best Value
                                                </div>
                                            {% endif %}                                       
                                        </div>
                                    </div>
