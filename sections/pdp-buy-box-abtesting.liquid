{{ 'pdp-buy-box.css' |  asset_url |  stylesheet_tag  }}

<style>
    #buy_box_form #appstle_subscription_widget0{
        display: none;
    }
    #buy_box_form .appstle_subscription_final_price,
    #buy_box_form .appstle_subscription_save{
        display: none;
    }
    
</style>
<section class="new_pdp_buy_box">
    <div class="buy_box_wrapper">
        {% assign selected_product = all_products['peck-purity-chicken-dewormer-abtesting'] %}
        {%- assign current_variant = selected_product.selected_or_first_available_variant -%}
        <div class="buy_box_innerwrapper">
            <div class="buy_box_content">
                <div class="bb_content_inner">                        
                    <div class="but_box_main">
                        <div class="bb_title">
                            <h2>1. Choose your flock size</h2>
                        </div>
                        <div class="flock_size_wrapper">
                            <div class="flock_options one_time"  style="display: none;">
                                
                                {% for variant in selected_product.variants %}                                  
                                        {% assign forloop_index_count1 = forloop.index %}
                                    <div class="gt-prod-var-box-sub {% if forloop.first %} active {% endif %}">
                                        <div class="flock_item">
                                            <input type="radio" class="v_radio" name="flock-size" id="{{  variant.title |  downcase |  replace:  ' ','-' }}" 
                                                data-v-title="{{ variant.title  }}"
                                                data-v-id="{{ variant.id }}"
                                                data-v-price="{{ variant.price | money_without_trailing_zeros }}"
                                                {% for allocation in variant.selling_plan_allocations %}
                                                    {% if forloop_index_count1 == forloop.index %}                                                                
                                                        {% assign original_price = current_variant.price | times: forloop_index_count1 %}
                                                        {% assign selling_price = allocation.price_adjustments[0].price %}
                                                        data-original-price="{{ original_price |  money }}"  
                                                        data-subs-price="{{ selling_price |  money }}"    
                                                        {% assign price_diff = original_price | minus: selling_price %}
                                                        {% assign discount_percentage = price_diff | times: 100 | divided_by: original_price %}
                                                        data-discount="{{ discount_percentage }}%"  
                                                        {% assign sub_sav_price = variant.compare_at_price |  minus: selling_price  %}
                                                        data-save-price="{{ sub_sav_price |  money }}"                                                        
                                                    {% endif %}
                                                {% endfor %}
                                                data-comp-price="{{ variant.compare_at_price | money_without_trailing_zeros  }}" 
                                                {% if variant.available %}
                                                    data-instock="true"
                                                {% else %}
                                                        data-instock="false"
                                                {% endif %}
                                                data-quantity="{{ forloop_index_count1 }}"    
                                                >  
                                            <div class="gt-prod-var-content">
                                                <label for="{{  variant.title |  downcase |  replace:  ' ','-' }}">
                                                    <div class="flock_info">
                                                         {% assign words = variant.title | split: ' ' %}
                                                        {% assign last_two = words | slice: -2, 2 | join: ' ' %}
                                                        {% assign first_part = variant.title | remove: last_two %}

                                                        <div class="f_size">
                                                            <p>{{ first_part }}</p>
                                                        </div>
                                                        <div class="p_size">
                                                            <p>{{ last_two }}</p>
                                                         </div>
                                                        {% comment %} <div class="f_size">
                                                            <p>{{  variant.title | replace: 'Birds ', 'Birds<br>' }}</p>
                                                        </div> {% endcomment %}
                                                        {% comment %} <div class="p_size">
                                                            {% if forloop.first %}
                                                                <p>1 Pouch</p>
                                                            {% elsif forloop.index == 2 %}
                                                                <p>2 Pouches</p>
                                                            {% elsif forloop.index == 3 %}
                                                                <p>3 Pouches</p>
                                                            {% elsif forloop.index == 4 %}
                                                                <p>4 Pouches</p>
                                                            {% else %}
                                                                <p>1 Pouch every 5 chicken</p>
                                                            {% endif %}
                                                        </div> {% endcomment %}
                                                        {% if variant.compare_at_price > variant.price %}
                                                            <div class="save-price">
                                                                {% assign save_price = variant.compare_at_price  |  minus: variant.price  %}
                                                                <p>Save {{ save_price |  money_without_trailing_zeros }}</p>
                                                            </div>
                                                        {% endif %}
                                                    </div>
                                                </label>
                                            </div>                                            
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                                <div class="flock_options subscribe_save">
                                
                                {% for variant in selected_product.variants %}                                  
                                    {% assign forloop_index_count = forloop.index %}
                                    <div class="gt-prod-var-box-sub {% if forloop.first %} active {% endif %}">
                                        <div class="flock_item">
                                                <input type="radio" class="v_radio" name="flock-size-ss" id="ss-{{  variant.title |  downcase |  replace:  ' ','-' }}" {% if forloop.first %} checked{% endif %}
                                                data-v-title="{{ variant.title  }}"
                                                data-v-id="{{ variant.id }}"
                                                data-v-price="{{ variant.price | money_without_trailing_zeros }}"
                                                {% for allocation in variant.selling_plan_allocations %}
                                                    {% if forloop_index_count == forloop.index %}                                                                
                                                        {% assign original_price = current_variant.price | times: forloop_index_count %}
                                                        {% assign selling_price = allocation.price_adjustments[0].price %}
                                                    data-original-price="{{ original_price |  money }}"  
                                                    data-subs-price="{{ selling_price |  money }}"    

                                                    {% assign price_diff = original_price | minus: selling_price %}
                                                    {% assign discount_percentage = price_diff | times: 100 | divided_by: original_price %}
                                                    data-discount="{{ discount_percentage }}%"  
                                                    {% assign sav_price = variant.compare_at_price |  minus: selling_price  %}
                                                    data-save-price="{{ sav_price |  money }}"
                                                    {% endif %}
                                                {% endfor %}

                                                data-comp-price="{{ variant.compare_at_price | money_without_trailing_zeros  }}"                                                        
                                                    {% if variant.available %}
                                                    data-instock="true"
                                                {% else %}
                                                        data-instock="false"
                                                {% endif %}    
                                                data-quantity="{{ forloop_index_count }}"                          
                                                >  
                                            <div class="gt-prod-var-content">
                                                <label for="ss-{{  variant.title |  downcase |  replace:  ' ','-' }}">
                                                    <div class="flock_info">
                                                        {% assign words = variant.title | split: ' ' %}
                                                        {% assign last_two = words | slice: -2, 2 | join: ' ' %}
                                                        {% assign first_part = variant.title | remove: last_two %}

                                                        <div class="f_size">
                                                            <p>{{ first_part }}</p>
                                                        </div>
                                                        <div class="p_size">
                                                            <p>{{ last_two }}</p>
                                                         </div>
                                                        {% comment %} <div class="f_size">
                                                             <p>{{  variant.title | replace: 'Birds ', 'Birds<br>' }}</p>
                                                        </div>
                                                        <div class="p_size">
                                                            {% if forloop.first %}
                                                                <p>1 Pouch</p>
                                                            {% elsif forloop.index == 2 %}
                                                                <p>2 Pouches</p>
                                                            {% elsif forloop.index == 3 %}
                                                                <p>3 Pouches</p>
                                                            {% elsif forloop.index == 4 %}
                                                                <p>4 Pouches</p>
                                                            {% else %}
                                                                <p>1 Pouch every 5 chicken</p>
                                                            {% endif %}
                                                        </div> {% endcomment %}
                                                        {% for allocation in variant.selling_plan_allocations %}
                                                            {% if forloop_index_count == forloop.index %}
                                                                
                                                                {% assign original_price = current_variant.price | times: forloop_index_count %}
                                                                {% assign selling_price = allocation.price_adjustments[0].price %}

                                                                {% assign price_diff = original_price | minus: selling_price %}
                                                                {% assign discount_percentage = price_diff | times: 100 | divided_by: original_price %}
                                                                
                                                                <div class="save-price">
                                                                    <p>Save {{ discount_percentage }}%</p>
                                                                </div>
                                                            {% endif %}
                                                        {% endfor %}
                                                    </div>
                                                </label>
                                            </div>                                            
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                            <div class="bb_title">
                            <h2>2. Choose your frequency</h2>
                        </div>
                        <div class="bb_frequancy_wrapper">
                            <div class="bb_frequancy_inner">
                                <div class="bbfreq_radio_wrapper">
                                    <div class="subs_label_inner">
                                        <img class="best_val_img" width="21" height="21" src="//cdn.shopify.com/s/files/1/0046/3716/3633/files/chicken-img.webp?v=1772692433">  
                                    <span>Best Value</span>
                                    </div>
                                    <input type="radio" id="subcribe" name="frequancy-radio" checked="checked" value="subscribe">
                                    <label for="subcribe" class="subscribe-label">
                                        <div class="frq_info">
                                            <p>Subscribe & save 20%                                                    
                                                <div class="save-price">Save $6.56</div>
                                            </p>
                                            <span class="ss-price">{{ current_variant.price |  money_without_trailing_zeros }}</span>
                                            <span class="ss-comp-price">{{ current_variant.compare_at_price |  money_without_trailing_zeros }}</span>

                                        </div>
                                        <div class="frequancy_details">
                                            <select name="select_frequancy" id="frquancy">
                                                    {% for group in selected_product.selling_plan_groups %}
                                                    {% for plan in group.selling_plans %}
                                                        {% assign subloop = forloop.index %}
                                                            <option value="{{ plan.id }}" {% if subloop == 1 %} selected="selected"{% endif %}>
                                                                {{ plan.name }}
                                                            </option>
                                                    {% endfor %}
                                                {% endfor %}
                                            </select>
                                            {% if section.settings.subsbenifit != blank %}
                                                <div class="ss_info_wrapper">
                                                    {{ section.settings.subsbenifit  }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </label>
                                </div>
                                <div class="bbfreq_radio_wrapper">
                                    <input type="radio" id="one-time" name="frequancy-radio" value="onetime">
                                    <label for="one-time" class="one-time-label">
                                        <div class="frq_info">
                                            <p>One Time Purchase</p>
                                            <span class="ot-price">{{ current_variant.price |  money_without_trailing_zeros }}</span>
                                        </div>
                                    </label>
                                </div>
                                
                            </div>
                        </div>
                    </div> 
                    <form method="post" action="{{ routes.cart_url }}" id="buy_box_form" accept-charset="UTF-8" class="form" enctype="multipart/form-data" novalidate="novalidate" data-type="add-to-cart-form">
                        <input type="hidden" name="form_type" value="product">
                        <input type="hidden" name="utf8" value="✓">
                        <input type="hidden" name="id" value="{{  current_variant.id }}" class="product-variant-id" data-quantity="1">
                        <div class="product-form__buttons ">
                            <button id="ProductSubmitButton-template--19995845492930__main" type="submit" name="add" class="product-form__submit button button--full-width button--primary" aria-haspopup="dialog">
                                {% if current_variant.available %} 
                                    <span>Add to cart- </span>
                                            {% else %}
                                    <span>Sold Out-</span>
                                {% endif %}
                                <div class="product-price">                                            
                                    <div class="compare-price">{{ current_variant.compare_at_price |  money_without_trailing_zeros }}</div>                                                                                          
                                    <div class="price">{{ current_variant.price |  money_without_trailing_zeros }}</div>                                                                                            
                                </div> 
                                <div class="loader">
                                    <img src="//cdn.shopify.com/s/files/1/0046/3716/3633/files/loader.gif?v=1772538563" alt="" width="" height="">
                                </div>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("change", function(e) {
        if (e.target.classList.contains("v_radio")) {

            document.querySelectorAll(".gt-prod-var-box-sub")
            .forEach(box => box.classList.remove("active"));

            e.target.closest(".gt-prod-var-box-sub")
            .classList.add("active");
        }
    });
</script>

<script>
$(document).ready(function(){

  $('.js-for-image-slider').slick({
    slidesToShow: 1,
    slidesToScroll: 1,
    arrows: true,
    fade: true,
    cssEase: 'linear',
    asNavFor: '.js-nav-image-slider'
  });

  $('.js-nav-image-slider').slick({
    slidesToShow: 7,
    slidesToScroll: 1,
    asNavFor: '.js-for-image-slider',
    dots: false,
    focusOnSelect: true,
    arrows: true
  });


  // On load fill the check value
  let subs_com_price =$('.flock_options.subscribe_save .gt-prod-var-box-sub .flock_item input:checked').attr('data-comp-price');
  let subs_price =$('.flock_options.subscribe_save .gt-prod-var-box-sub .flock_item input:checked').attr('data-subs-price');
  let sav_price = $('.flock_options.subscribe_save .gt-prod-var-box-sub .flock_item input:checked').attr('data-save-price');
  let original_price = $('.flock_options.subscribe_save .gt-prod-var-box-sub .flock_item input:checked').attr('data-original-price');
  $('.bbfreq_radio_wrapper .subscribe-label .frq_info .save-price').text(sav_price);
  $('.bbfreq_radio_wrapper .subscribe-label .frq_info .ss-price').text(subs_price);
  $('.bbfreq_radio_wrapper .subscribe-label .frq_info .ss-comp-price').text(subs_com_price);
  $('.product-form__buttons .product-form__submit .product-price .price').text(subs_price);
  $('.product-form__buttons .product-form__submit .product-price .compare-price').text(subs_com_price);
  $('.bbfreq_radio_wrapper .frq_info .ot-price').text(original_price);


  // On subscribe button chnage prices
  $('.flock_options .gt-prod-var-box-sub .flock_item input').on('click', function(){
        let com_p = $(this).attr('data-comp-price');
        let sub_p = $(this).attr('data-subs-price');
        let save_p = $(this).attr('data-save-price');
        let s_price = $(this).attr('data-v-price');
        let original_price = $('.flock_options.subscribe_save .gt-prod-var-box-sub .flock_item input:checked').attr('data-original-price');
        let v_id = $(this).attr('data-v-id');
        //let update_quanityt = $(this).attr('data-quantity');
        $('#buy_box_form .product-variant-id').val(v_id);
        //$('#buy_box_form .product-variant-id').attr('data-quantity', update_quanityt);
        $('.bbfreq_radio_wrapper .subscribe-label .frq_info .save-price').text(save_p);
        $('.bbfreq_radio_wrapper .subscribe-label .frq_info .ss-price').text(sub_p);
        $('.bbfreq_radio_wrapper .subscribe-label .frq_info .ss-comp-price').text(com_p);
        let check_name = $('.bb_frequancy_inner .bbfreq_radio_wrapper input:checked').val();
        if(check_name == 'onetime'){
            $('.product-form__buttons .product-form__submit .product-price .price').text(s_price);
        }else{
            $('.product-form__buttons .product-form__submit .product-price .price').text(sub_p);
        }     
        $('.product-form__buttons .product-form__submit .product-price .compare-price').text(com_p);
        $('.bbfreq_radio_wrapper .frq_info .ot-price').text(s_price);   
        let instock = $(this).attr('data-instock');
        if(instock == 'false'){
            $('.product-form__submit').attr('disabled','disabled');
            $('.product-form__submit span').text('Sold Out-');
        }else{
            $('.product-form__submit').removeAttr('disabled');
            $('.product-form__submit span').text('Add to cart-');
        }

  });

  $('.bb_frequancy_inner .bbfreq_radio_wrapper input').on('click',function(){
    let check_name  = $(this).val();
    if(check_name == 'onetime'){
      $('.flock_options.one_time').show();
      $('.flock_options.subscribe_save').hide();
      let ot_c_price = $('.flock_options.one_time .gt-prod-var-box-sub .flock_item input:checked').attr('data-comp-price');
      let ot_original_price = $('.flock_options.one_time .gt-prod-var-box-sub .flock_item input:checked').attr('data-v-price');
      console.log('ot_original_price',ot_original_price);
      let ot_save_price = $('.flock_options.one_time .gt-prod-var-box-sub .flock_item input:checked').attr('data-save-price');
      let sub_original_price = $('.flock_options.one_time .gt-prod-var-box-sub .flock_item input:checked').attr('data-subs-price');
      $('.bbfreq_radio_wrapper .subscribe-label .frq_info .save-price').text(ot_save_price);
      $('.bbfreq_radio_wrapper .subscribe-label .frq_info .ss-price').text(sub_original_price);
      $('.bbfreq_radio_wrapper .subscribe-label .frq_info .ss-comp-price').text(ot_c_price);
      $('.product-form__buttons .product-form__submit .product-price .price').text(ot_original_price);
      $('.product-form__buttons .product-form__submit .product-price .compare-price').text(ot_c_price);
      $('.bbfreq_radio_wrapper .frq_info .ot-price').text(ot_original_price);
      $('.flock_options.one_time .gt-prod-var-box-sub:first-child .flock_item input').trigger('click');
      $('.flock_options.one_time .gt-prod-var-box-sub:first-child').addClass('active');
    }else{
      $('.flock_options.one_time').hide();
      $('.flock_options.subscribe_save').show();
       let ot_c_price = $('.flock_options.subscribe_save .gt-prod-var-box-sub .flock_item input:checked').attr('data-comp-price');
      let ot_original_price = $('.flock_options.subscribe_save .gt-prod-var-box-sub .flock_item input:checked').attr('data-v-price');
      let ot_save_price = $('.flock_options.subscribe_save .gt-prod-var-box-sub .flock_item input:checked').attr('data-save-price');
      let sub_original_price = $('.flock_options.subscribe_save .gt-prod-var-box-sub .flock_item input:checked').attr('data-subs-price');
      $('.bbfreq_radio_wrapper .subscribe-label .frq_info .save-price').text(ot_save_price);
      $('.bbfreq_radio_wrapper .subscribe-label .frq_info .ss-price').text(sub_original_price);
      $('.bbfreq_radio_wrapper .subscribe-label .frq_info .ss-comp-price').text(ot_c_price);
      $('.product-form__buttons .product-form__submit .product-price .price').text(ot_original_price);
      $('.product-form__buttons .product-form__submit .product-price .compare-price').text(ot_c_price);
      $('.bbfreq_radio_wrapper .frq_info .ot-price').text(ot_original_price);
      $('.flock_options.subscribe_save .gt-prod-var-box-sub:first-child .flock_item input').trigger('click');
      $('.flock_options.subscribe_save .gt-prod-var-box-sub:first-child').addClass('active');
    }
  });

  $('.product-form__submit').on('click',function(e){
    e.preventDefault();
    let $this = $(this);
    $this.attr('disabled','disabled');
    $this.find('.loader').addClass('show');
    var itemsArray = [];
    let var_id = $('.product-variant-id').val();
    //let qnty = $('.product-variant-id').attr('data-quantity');
    var fre_op =  $('.bb_frequancy_inner .bbfreq_radio_wrapper input:checked').val();
    if(fre_op == 'onetime'){
        var customItem = [
          {
            id: var_id,
            quantity: 1
          }
        ];
      itemsArray.push(...customItem);
    }else{
        var selling_plan_id = $('#frquancy option:selected').val();     
        var customItem = [{
          id: var_id,
          quantity: 1,
          selling_plan: selling_plan_id
        }];
        itemsArray.push(...customItem);
    }

    $.ajax({
        url: '/cart/add.js',
        method: "POST",
        dataType: "JSON",
        data: { items: itemsArray },
        success: function (data) {
           fetch(`${window.location.pathname}?sections=cart-drawer,cart-icon-bubble`)
              .then(response => response.json())
              .then((sections) => {
                // Update cart bubble
                const cartBubble = document.querySelector('#cart-icon-bubble');
                const newBubble = new DOMParser()
                    .parseFromString(sections['cart-icon-bubble'], 'text/html')
                    .querySelector('#cart-icon-bubble');

                if (cartBubble && newBubble) {
                    cartBubble.innerHTML = newBubble.innerHTML;
                }

                // Update cart drawer
                const cartDrawer = document.querySelector('cart-drawer');
                if (cartDrawer) {
                    cartDrawer.renderContents({
                        sections: sections
                    });
                }
                document.querySelector('#cart-icon-bubble').click();
            });

          $this.find('.loader').removeClass('show');
          $this.removeAttr('disabled');
        },
          error: function (data) {
        }
    });

  });
});

</script>
 <script>
    window.addEventListener("load", function () {
        const sectionToMove = document.querySelector('#buy_box_form');
        const targetSection = document.querySelector('[data-extra-section="add-on"]');

        if (sectionToMove && targetSection) {
            targetSection.after(sectionToMove);
        }
    });
</script> 
