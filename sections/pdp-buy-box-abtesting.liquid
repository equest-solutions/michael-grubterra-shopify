<style>
    #buy_box_form #appstle_subscription_widget0{
        display: none;
    }
    #buy_box_form .appstle_subscription_final_price,
    #buy_box_form .appstle_subscription_save{
        display: none;
    }

    .but_box_main .flock_size_wrapper .flock_options .gt-prod-var-box-sub{
        width: calc(33% - 5px);
    }

    .but_box_main .flock_size_wrapper .flock_options{
        justify-content: space-between;
    }
    
    .but_box_main .flock_size_wrapper .flock_options .gt-prod-var-box-sub .flock_item{
        position: relative;
    }

    .but_box_main .flock_size_wrapper .flock_options .gt-prod-var-box-sub .flock_item .badge {
        position: absolute;
        top: -15px;
        left: 0;
        right: 0;
        display: flex;
        max-width: max-content;
        text-align: center;
        width: max-content;
        margin: 0 auto;
        background-color: transparent;
        border: 0px solid #1f6223;
        padding: 5px 8px;
        color: #fff;
        font-weight: 700;
        z-index: 333;
        overflow: hidden;
        letter-spacing: 0;
        text-transform: uppercase;
        font-size: 10px;
    }

    .but_box_main .flock_size_wrapper .flock_options .gt-prod-var-box-sub .flock_item .badge.most-popular{
        background-color: #4182f5;
    }
     .but_box_main .flock_size_wrapper .flock_options .gt-prod-var-box-sub .flock_item .badge.free-shipping{
        background-color: #4182f5;
    }
     .but_box_main .flock_size_wrapper .flock_options .gt-prod-var-box-sub .flock_item .badge.best-value{
        background-color: #1ec35a;
    }
    .but_box_main .flock_size_wrapper .flock_options{
        column-gap: 10px;        
        row-gap: 35px;
    }
    .gt-prod-var-content{
        padding: 12px 10px 10px 10px;
    }
    @media (max-width: 767px){
        .but_box_main .flock_size_wrapper .flock_options .gt-prod-var-box-sub {
            width: calc(50% - 5px);
        }

        .but_box_main .flock_size_wrapper .flock_options{
            row-gap: 25px;
            column-gap: 5px;
        }
