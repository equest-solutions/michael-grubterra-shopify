                                                    Free Shipping
                                                </div>
                                            {% elsif forloop_index_count1 == 5  %}
                                                <div class="badge free-shipping">
                                                    Free Shipping
                                                </div>
                                            {% elsif forloop_index_count1 == 6  %}
