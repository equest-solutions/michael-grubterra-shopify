</section>

<script>
    document.addEventListener("change", function(e) {
        if (e.target.classList.contains("v_radio")) {

            document.querySelectorAll(".gt-prod-var-box-sub")
            .forEach(box => box.classList.remove("active"));

            e.target.closest(".gt-prod-var-box-sub")
            .classList.add("active");
        }
    });
</script>

<script>
$(document).ready(function(){

  /* -----------------------------
     UPDATE UI FUNCTION
  ----------------------------- */
  function updateUI($input){
    let com_p = $input.attr('data-comp-price');
    let sub_p = $input.attr('data-subs-price');
    let save_p = $input.attr('data-save-price');
    let s_price = $input.attr('data-v-price');
    let v_id = $input.attr('data-v-id');
    let instock = $input.attr('data-instock');

    let mode = $('input[name="frequancy-radio"]:checked').val();

    // Set variant ID
    $('#buy_box_form .product-variant-id').val(v_id);

    // Prices update
    $('.subscribe-label .save-price').text(save_p);
    $('.subscribe-label .ss-price').text(sub_p);
    $('.subscribe-label .ss-comp-price').text(com_p);
    $('.frq_info .ot-price').text(s_price);

    if(mode == 'onetime'){
      $('.product-form__submit .price').text(s_price);
    } else {
      $('.product-form__submit .price').text(sub_p);
    }

    $('.product-form__submit .compare-price').text(com_p);

    // Stock handling
    if(instock == 'false'){
      $('.product-form__submit').attr('disabled','disabled');
      $('.product-form__submit span').text('Sold Out-');
    } else {
      $('.product-form__submit').removeAttr('disabled');
      $('.product-form__submit span').text('Add to cart-');
    }
  }

  /* -----------------------------
     SYNC VARIANT BETWEEN MODES
  ----------------------------- */
  function syncVariant(targetWrapper, variantId){
    let target = targetWrapper.find(`input[data-v-id="${variantId}"]`);
    if(target.length){
      target.prop('checked', true);
      target.closest('.gt-prod-var-box-sub').addClass('active');
      updateUI(target);
    }
  }

  function getSelectedVariant(wrapper){
    return wrapper.find('.flock_item input:checked').attr('data-v-id');
  }

  /* -----------------------------
     VARIANT CLICK
  ----------------------------- */
  $('.flock_options .flock_item input').on('click', function(){

    $(this).closest('.flock_options')
           .find('.gt-prod-var-box-sub')
           .removeClass('active');

    $(this).closest('.gt-prod-var-box-sub')
           .addClass('active');

    updateUI($(this));
  });

  /* -----------------------------
     FREQUENCY SWITCH
  ----------------------------- */
  $('input[name="frequancy-radio"]').on('change', function(){

    let mode = $(this).val();

    if(mode == 'onetime'){

      let selectedId = getSelectedVariant($('.subscribe_save'));

      $('.subscribe_save').hide();
      $('.one_time').show();

      syncVariant($('.one_time'), selectedId);

    } else {

      let selectedId = getSelectedVariant($('.one_time'));

      $('.one_time').hide();
      $('.subscribe_save').show();

      syncVariant($('.subscribe_save'), selectedId);
    }
  });

  /* -----------------------------
     INITIAL LOAD
  ----------------------------- */
  let initialInput = $('.subscribe_save .flock_item input:checked');
  updateUI(initialInput);

  /* -----------------------------
     ADD TO CART (AJAX)
  ----------------------------- */
  $('.product-form__submit').on('click', function(e){
    e.preventDefault();

    let $btn = $(this);
    $btn.attr('disabled','disabled');
    $btn.find('.loader').addClass('show');

    let itemsArray = [];

    let variantId = $('#buy_box_form .product-variant-id').val();
    let mode = $('input[name="frequancy-radio"]:checked').val();

    if(mode == 'onetime'){

      itemsArray.push({
        id: variantId,
        quantity: 1
      });

    } else {

      let selling_plan_id = $('#frquancy option:selected').val();

      itemsArray.push({
        id: variantId,
        quantity: 1,
        selling_plan: selling_plan_id
      });
    }

    $.ajax({
      url: '/cart/add.js',
      method: 'POST',
      dataType: 'JSON',
      data: { items: itemsArray },

      success: function(){

        // Refresh cart UI
        fetch(`${window.location.pathname}?sections=cart-drawer,cart-icon-bubble`)
          .then(res => res.json())
          .then((sections) => {

            // Update cart bubble
            let bubble = document.querySelector('#cart-icon-bubble');
            let newBubble = new DOMParser()
              .parseFromString(sections['cart-icon-bubble'], 'text/html')
              .querySelector('#cart-icon-bubble');

            if(bubble && newBubble){
              bubble.innerHTML = newBubble.innerHTML;
            }

            // Update drawer
            let drawer = document.querySelector('cart-drawer');
            if(drawer){
              drawer.renderContents({ sections });
            }

            document.querySelector('#cart-icon-bubble').click();
          });

        $btn.find('.loader').removeClass('show');
        $btn.removeAttr('disabled');
      },

      error: function(err){
        console.error('Cart error:', err);

        $btn.find('.loader').removeClass('show');
        $btn.removeAttr('disabled');

        alert('Something went wrong. Please try again.');
      }

    });

  });

});
</script>
 <script>
    window.addEventListener("load", function () {
        const sectionToMove = document.querySelector('#buy_box_form');
        const targetSection = document.querySelector('[data-extra-section="add-on"]');

        if (sectionToMove && targetSection) {
            targetSection.after(sectionToMove);
        }
    });
</script> 
