{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}
 

{{ 'section-announcement-bar.css' | asset_url | stylesheet_tag }}
{% capture text_check  %}
<svg width="12" height="9" viewBox="0 0 12 9" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
<rect width="12" height="8.57143" fill="url(#pattern0)"/>
<defs>
<pattern id="pattern0" patternContentUnits="objectBoundingBox" width="1" height="1">
<use xlink:href="#image0_247_294" transform="scale(0.00510204 0.00714286)"/>
</pattern>
<image id="image0_247_294" width="196" height="140" xlink:href="data:image/png;base64,"/>
</defs>
</svg>

{% endcapture %}
<div class="header-section--padding announcement-background">
  <div class="page-width">
    <announcement-bar class="announcement-bar-swiper">
      <div class="announcement-slider swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide">
            {%- if block.settings.link != blank -%}
              <a class="announcement-link" href="{{ block.settings.link }}">
            {%- endif -%}
                <span class="announcement-text">{{ text_check }} {{ block.settings.text | escape }}</span>
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
       </div>
    </announcement-bar>
  </div>
</div>
  
<script src="{{ 'announcement-bar-2.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Announcement bar",
  "class": "shopify-section-announcement-bar",
  "max_blocks": 4,
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
    ]
  },
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
