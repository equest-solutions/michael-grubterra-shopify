  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600&display=swap');

  #delivery-date-desktop {
    font-family: Poppins;
    font-weight: 600; /* Semi-bold */
    color: #1F6223;
    text-decoration: underline;
  }

    #delivery-date-mobile {
    font-family: Poppins;
    font-weight: 600; /* Semi-bold */
    color: #1F6223;
    text-decoration: underline;
  }

</style>

<div id="delivery-date-desktop"></div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Function to format the date as "Month Day" (e.g., "Nov 15")
    function formatDate(date) {
      const options = { month: 'short', day: 'numeric' };
      return new Intl.DateTimeFormat('en-US', options).format(date);
    }

    // Calculate current date and add 5 and 7 days for the delivery range
    const currentDate = new Date();
    const date1 = new Date(currentDate);
    date1.setDate(currentDate.getDate() + 5); // 5 days from now
    const date2 = new Date(currentDate);
    date2.setDate(currentDate.getDate() + 7); // 7 days from now

    // The formatted date range
    const deliveryDateText = `${formatDate(date1)} - ${formatDate(date2)}`;

    // Display the result in both desktop and mobile elements, if they exist
    const desktopElement = document.getElementById('delivery-date-desktop');
    const mobileElement = document.getElementById('delivery-date-mobile');
    if (desktopElement) desktopElement.textContent = deliveryDateText;
    if (mobileElement) mobileElement.textContent = deliveryDateText;
