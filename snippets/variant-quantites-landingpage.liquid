{% liquid
  assign is_bundle = false
  for tag in product.tags
    if tag contains "bundle"
      assign is_bundle = true
    endif
  endfor

  if is_bundle
    assign bundle_handle1 = product.handle | append: "-bundle-1"
    assign bundle_handle2 = product.handle | append: "-bundle-2"
    assign bundle_handle5 = product.handle | append: "-bundle-5"

    assign bundle_product_1 = all_products[bundle_handle1]
    assign bundle_product_2 = all_products[bundle_handle2]
    assign bundle_product_5 = all_products[bundle_handle5]
  endif
%}

<variant-quantities class="variant-quantity-wrapper-container">
  <input type="hidden" name="properties[note]" class="js-note" form="{{ product_form_id }}">
  <input type="hidden" name="properties[_fulfillments-count]" class="js-fulfillment-count" form="{{ product_form_id }}">
  <input type="hidden" name="properties[_sales-unit]" class="js-sales-unit" form="{{ product_form_id }}">


  {% for variant in product.variants %}
    {% render "variant-quantity-landingpage", variant: variant %}
  {% endfor %}

  {% if bundle_product_1 != blank %}
    {% render "variant-quantity-landingpage", variant: bundle_product_1.selected_or_first_available_variant, quantity: 1 %}
  {% endif %}

  {% if bundle_product_2 != blank %}
    {% render "variant-quantity-landingpage", variant: bundle_product_2.selected_or_first_available_variant, quantity: 2 %}
  {% endif %}

  {% if bundle_product_5 != blank %}
    {% render "variant-quantity-landingpage", variant: bundle_product_5.selected_or_first_available_variant, quantity: 5 %}
  {% endif %}
</variant-quantities>

<script src="{{ 'variant-quantities.js' | asset_url }}" defer></script>

<style>


.variant-quantity-wrapper input[type=radio]:checked+.variant-quantity-wrapper-variant-wrapper {background:white !important;}


  .discout-percent {display:none;}
  .discount-percent-wrapper, .variant-quantity-radio {visibility:hidden; display:none !important;}
  .variant-quantity-wrapper-variant-wrapper {
    flex:none;
    height:260px;
    width:140px;
    flex-direction: column;
    justify-content:space-around;
    gap:10px;
background-color:white;
  }



.variant-quantity-variant-name {text-align:center;}
  .variant-quantity-variant {flex:none;}
  .variant-quantity-wrapper-container {flex-direction:row;}
  .variant-quantity-weight {text-align:center;}
  .variant-quantity-price {justify-content:center;}
  .variant-quantity-variant-name {font-family:"Brother1816 Printed Bold"; font-size:16px; color: #1f6223; font-weight:600;}
  .variant-quantity-price-compare, .variant-quantity-price-regular {font-size:14px; font-family:"Brother1816 Printed";}
  .variant-quantity-price-regular {color:black;}
  .variant-quantity-weight {font-size:12px; font-family:"Brother1816 Printed"; font-weight:500; }
  .variant-quantity-price-weight {flex:none;}


 @media(max-width: 600px){ 
.variant-quantity-price {justify-content:start;}

.variant-quantity-variant {
    display: flex;
    flex-direction: column;

}
.variant-quantity-variant-name {width:fit-content;}

.best-deal-wrapper{
    position: absolute;

    right: 0;

    bottom: 0;
    width: 100px;
    height: 25px;
    border-radius: 25px;

}


.beast-deal {border-radius:25px;}
.variant-quantity-wrapper {position:relative;}

.variant-quantity-savings {max-width:100px; flex-shrink:0;}
.variant-img {width:70px; flex-shrink:0; display:flex;}


.variant-quantity-weight {text-align:left;}
.variant-quantity-wrapper-container {gap:15px;}
.variant-quantity-wrapper-container {flex-direction:column;}
.variant-quantity-wrapper-variant-wrapper {flex-direction:row; height:100px; width:100%; justify-content: center; gap:20px;}

}

</style>