{% liquid
  assign is_bundle = false
  for tag in product.tags
    if tag contains "bundle"
      assign is_bundle = true
    endif
  endfor

  if is_bundle

    assign bundle_handle1 = product.handle | append: "-bundle-1"
    assign bundle_handle2 = product.handle | append: "-bundle-2"
    assign bundle_handle5 = product.handle | append: "-bundle-5"

    assign bundle_product_1 = all_products[bundle_handle1]
    assign bundle_product_2 = all_products[bundle_handle2]
    assign bundle_product_5 = all_products[bundle_handle5]
  




endif
%}

<!-- Added Chicken Count UI -->
<div class="chicken-count-selector">
<div class="chicken-wrap">
  <label for="chicken-count" class=chicken-label>How many chickens do you have?</label>
<!-- Add the "How do I choose?" link and modal popup above variant-quantities -->
<div class="how-to-choose-container">
  <a href="#" id="how-to-choose-link">How do I choose?</a>
</div>
</div>

<!-- Modal structure -->
<div id="how-to-choose-popup" class="popup-overlay">
  <div class="popup-content">
    <h2>How do I choose my quantity?</h2>
    <p>
      The quantities below are recommended estimates. We are basing these estimates on a 16% layer feed diet. We estimate that each chicken will consume .352oz per day or roughly 10 grams of black soldier fly larvae. If you want a more exact estimate on how much larvae your chickens will consume per day, you can find this by multiplying the per day by the number of chickens you have.
    </p>
    <button id="close-popup">Close</button>
  </div>
</div>

