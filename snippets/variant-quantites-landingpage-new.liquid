<!-- Existing Variant Quantities Block -->
<div id="product-render"></div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const defaultValue = '5-10';
  let isSubscribeSelected = true; // Tracks whether "Subscribe" is active

  // Update variant durations based on chicken count and frequency selection
  function updateVariantDurations(chickenCount) {
    const durationMapping = {
      '5-10': {
        '5lb': 'Every 1 Month',
        '10lb': 'Every 2 Months',
        '20lbs': 'Every 4 Months',
        '50lbs': 'Every 5 Months',
      },
      '11-20': {
        '5lb': 'Every 2 Weeks',
        '10lb': 'Every 1 Month',
        '20lbs': 'Every 2 Months',
        '50lbs': 'Every 5 Months',
      },
      '21-30': {
        '5lb': 'Every 1 Week',
        '10lb': 'Every 2 Weeks',
        '20lbs': 'Every 1 Month',
        '50lbs': 'Every 3 Months',
      },
      '31-40+': {
        '5lb': 'Every 1 Week',
        '10lb': 'Every 2 Weeks',
        '20lbs': 'Every 1 Month',
        '50lbs': 'Every 2 Months',
      },
    };

    const durationInfo = durationMapping[chickenCount];
    if (!durationInfo) {
      console.warn('No duration mapping found for chicken count:', chickenCount);
      return;
    }

    document.querySelectorAll('.variant-quantity-wrapper').forEach((wrapper) => {
      const variantId = wrapper.querySelector('.js-variant-quantity')?.getAttribute('data-variant-name')?.trim();
      const durationDiv = wrapper.querySelector('#duration');
      if (durationDiv) {
        if (isSubscribeSelected && variantId && durationInfo[variantId]) {
          durationDiv.textContent = `1 Bag: ${durationInfo[variantId]}`;
        } else {
          durationDiv.textContent = ''; // Clear the text if "One Time Purchase" is selected
        }
      }
    });
  }

  // Render the product variants dynamically
  function renderProductVariants(selectedValue) {
    const productRenderDiv = document.getElementById('product-render');
    productRenderDiv.innerHTML = `
      <variant-quantities class="variant-quantity-wrapper-container">
        <input type="hidden" name="properties[note]" class="js-note" form="{{ product_form_id }}">
        <input type="hidden" name="properties[_fulfillments-count]" class="js-fulfillment-count" form="{{ product_form_id }}">
        <input type="hidden" name="properties[_sales-unit]" class="js-sales-unit" form="{{ product_form_id }}">
        {% for variant in product.variants %}
          {% render "variant-quantity-landingpage-new", variant: variant %}
        {% endfor %}
        {% if bundle_product_1 != blank %}
          {% render "variant-quantity-landingpage-new", variant: bundle_product_1.selected_or_first_available_variant, quantity: 1 %}
        {% endif %}
        {% if bundle_product_2 != blank %}
          {% render "variant-quantity-landingpage-new", variant: bundle_product_2.selected_or_first_available_variant, quantity: 2 %}
        {% endif %}
        {% if bundle_product_5 != blank %}
          <div class="last-item">
            {% render "variant-quantity-landingpage-new", variant: bundle_product_5.selected_or_first_available_variant, quantity: 5 %}
          </div>
        {% endif %}
      </variant-quantities>`;
    setTimeout(() => updateVariantDurations(selectedValue), 0);
  }

  // Preselect "5-10" chicken count on page load
  document.querySelectorAll('input[name="chicken-count"]').forEach((input) => {
    if (input.value === defaultValue) {
      input.checked = true;
      renderProductVariants(defaultValue); // Explicitly render for the default chicken count
    }
  });

  // Handle chicken count changes
  document.querySelectorAll('input[name="chicken-count"]').forEach((input) => {
    input.addEventListener('change', (event) => {
      const selectedValue = event.target.value;
      renderProductVariants(selectedValue);
    });
  });

  // Preselect the "Subscribe" option on page load
  const subscribeButton = document.querySelector('.frequency-option.subscribe');
  if (subscribeButton) {
    subscribeButton.classList.add('active');
    isSubscribeSelected = true; // Ensure "Subscribe" is active by default
  }

  // Handle "One Time Purchase" and "Subscribe" selection
  document.querySelectorAll('.frequency-option').forEach((button) => {
    button.addEventListener('click', function () {
      document.querySelectorAll('.frequency-option').forEach((btn) => btn.classList.remove('active'));
      this.classList.add('active');

      if (this.classList.contains('one-time')) {
        console.log('One Time Purchase selected');
        isSubscribeSelected = false;
      } else if (this.classList.contains('subscribe')) {
        console.log('Subscribe selected');
        isSubscribeSelected = true;
      }

      // Update the variant durations based on the selected frequency
      const selectedChickenCount = document.querySelector('input[name="chicken-count"]:checked')?.value;
      if (selectedChickenCount) {
        updateVariantDurations(selectedChickenCount);
      }
    });
  });
});
</script>





